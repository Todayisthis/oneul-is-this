rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 방명록: 누구나 읽기/작성, 삭제는 서버 Admin SDK 경유
    match /feeds/{docId} {
      allow create: if request.resource.data.keys().hasAll(['foodName', 'foodEmoji', 'comment', 'createdAt'])
                    && request.resource.data.comment is string
                    && request.resource.data.comment.size() <= 200
                    && request.resource.data.foodName is string
                    && request.resource.data.foodName.size() <= 50;
      allow read: if true;
      allow update, delete: if false;
    }

    // 후기: 누구나 작성·읽기, 삭제는 클라이언트 불가 (서버 Admin SDK 경유)
    match /reviews/{docId} {
      allow create: if request.resource.data.keys().hasAll(['type', 'itemName', 'rating', 'content', 'createdAt'])
                    && request.resource.data.content is string
                    && request.resource.data.content.size() <= 500
                    && request.resource.data.rating is int
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']);
      allow delete: if false;
    }

    // 댓글: 누구나 작성·읽기, 삭제는 클라이언트 불가
    match /review_comments/{docId} {
      allow create: if request.resource.data.keys().hasAll(['reviewId', 'content', 'createdAt'])
                    && request.resource.data.content is string
                    && request.resource.data.content.size() <= 300;
      allow read: if true;
      allow update, delete: if false;
    }

    // 통계용 픽 기록: 읽기만 허용, 쓰기는 서버 Admin SDK 경유
    match /foodPicks/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /watchPicks/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // 문의/제안: 누구나 작성 (길이 제한)
    match /contacts/{docId} {
      allow create: if request.resource.data.message is string
                    && request.resource.data.message.size() <= 1000;
    }
    match /suggestions/{docId} {
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.description is string
                    && request.resource.data.description.size() <= 500;
    }

    // 그 외 모든 컬렉션 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
